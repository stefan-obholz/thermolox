    "custom_liquid_BTYTwW": {
      "type": "custom-liquid",
      "name": "Schieber",
      "settings": {
        "custom_liquid": "<div class=\"ba-container\">\n  <div class=\"ba-wrapper\">\n    <!-- COOL jetzt zuerst (links sichtbar) -->\n    <img src=\"https://cdn.shopify.com/s/files/1/0974/3178/1717/files/HAUS_SCHIEBER_COOL.png?v=1756748492\" class=\"ba-image\" alt=\"COOL\">\n    \n    <!-- HOT jetzt überlagert (rechts) -->\n    <img src=\"https://cdn.shopify.com/s/files/1/0974/3178/1717/files/HAUS_SCHIEBER_HOT.png?v=1756748493\" class=\"ba-image ba-overlay\" id=\"coolImage\" alt=\"HOT\">\n\n    <div class=\"ba-handle\" id=\"baHandle\">\n      <span class=\"ba-arrow left\">‹</span>\n      <span class=\"ba-arrow right\">›</span>\n    </div>\n\n    <input type=\"range\" min=\"0\" max=\"100\" value=\"50\" class=\"ba-slider\" id=\"slider\">\n  </div>\n</div>\n\n<style>\n.ba-container {\n  width: 100%;\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n.ba-wrapper {\n  position: relative;\n  width: 100%;\n  overflow: hidden;\n  aspect-ratio: 16/6; /* Bildhöhe definieren! */\n  background: #000;\n}\n\n.ba-image {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.ba-overlay {\n  z-index: 2;\n  clip-path: inset(0 50% 0 0);\n  transition: clip-path 0.2s ease-out;\n}\n\n.ba-slider {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  opacity: 0;\n  z-index: 4;\n  cursor: ew-resize;\n}\n\n.ba-handle {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  height: 100%;\n  width: 0;\n  z-index: 5;\n  pointer-events: none;\n}\n\n.ba-handle::before {\n  content: \"\";\n  position: absolute;\n  height: 100%;\n  width: 2px;\n  background-color: white;\n  left: 50%;\n  transform: translateX(-50%);\n}\n\n.ba-arrow {\n  position: absolute;\n  top: 50%;\n  transform: translateY(-50%);\n  background: white;\n  color: black;\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 22px;\n  font-weight: bold;\n  box-shadow: 0 0 8px rgba(0,0,0,0.3);\n}\n\n.ba-arrow.left {\n  left: -50px;\n}\n\n.ba-arrow.right {\n  right: -50px;\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  const slider = document.getElementById(\"slider\");\n  const coolImage = document.getElementById(\"coolImage\");\n  const handle = document.getElementById(\"baHandle\");\n\n  function updateSlider(value) {\n    const percent = 100 - parseInt(value);\n    coolImage.style.clipPath = `inset(0 ${percent}% 0 0)`;\n    handle.style.left = `${value}%`;\n  }\n\n  if (slider && coolImage && handle) {\n    slider.addEventListener(\"input\", function () {\n      updateSlider(this.value);\n    });\n\n    // initial setzen\n    updateSlider(slider.value);\n  }\n});\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
    "rich_text_tKx9r9": {
      "type": "rich-text",
      "blocks": {
        "text_dhJYVB": {
          "type": "text",
          "settings": {
            "text": "<p>Unser Wärmebild-Vergleich zeigt eindrucksvoll die Wirkung des EVERLOXX-Systems: Links ein unbehandeltes Gebäude – rechts ein Haus, das mit <strong>THERMO-COAT</strong> gestrichen und mit <strong>THERMO-SEAL</strong> abgedichtet wurde.</p><p>💡 Weniger Wärmeverlust bedeutet:<br/><strong>Weniger Heizkosten. Mehr Komfort. Besser fürs Klima.</strong></p><p><br/></p><p>✅ Ideal für Altbau & unsanierte Gebäude</p><p>✅ Spart bis zu 42 % Heiz- und Kühlkosten</p><p>✅ Sofortige Wirkung nach der Anwendung</p><p>✅ Ohne Handwerker oder Umbau</p><p></p><p><br/></p><p><strong>Energie sparen war noch nie so einfach.</strong></p><p>Setze auf das EVERLOXX-System – die nachhaltige, rückbaufreie und günstige Alternative zur klassischen Sanierung.</p>"
          }
        },
        "button_KEUaey": {
