      "type": "custom-liquid",
      "name": "Abgedunkeltes Video",
      "settings": {
        "custom_liquid": "<div class=\"darkmode-scroll-section\">\n\n<h1 class=\"h1\"><strong>Was, wenn deine Wand wie eine Thermoskanne funktioniert?</strong></h1>\n\n  <h3></h3>\n\n  <div class=\"video-wrapper\">\n    <iframe \n      src=\"https://www.youtube.com/embed/CAyWN9ba9J8\" \n      title=\"YouTube video\" \n      frameborder=\"0\" \n      allowfullscreen>\n    </iframe>\n  </div>\n</div>\n\n<style>\n  :root {\n    --transition-speed: 1s;\n  }\n\n  body {\n    transition: filter var(--transition-speed) ease;\n  }\n\n  body img,\n  body video,\n  body iframe {\n    transition: filter var(--transition-speed) ease;\n  }\n\n  body.scroll-dark-invert {\n    filter: invert(1) hue-rotate(180deg);\n  }\n\n  body.scroll-dark-invert img,\n  body.scroll-dark-invert video,\n  body.scroll-dark-invert iframe {\n    filter: invert(1) hue-rotate(180deg);\n  }\n\n  .darkmode-scroll-section {\n    padding: 100px 20px;\n    text-align: center;\n    background-color: transparent;\n  }\n\n  .darkmode-scroll-section h2,\n  .darkmode-scroll-section p {\n    margin-bottom: 20px;\n  }\n\n  .video-wrapper {\n    position: relative;\n    width: 100%;\n    max-width: 800px;\n    margin: 0 auto;\n    aspect-ratio: 16 / 9;\n  }\n\n  .video-wrapper iframe {\n    width: 100%;\n    height: 100%;\n    border: none;\n  }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const section = document.querySelector('.darkmode-scroll-section');\n\n    if (!section) return;\n\n    const observer = new IntersectionObserver(\n      function (entries) {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            document.body.classList.add('scroll-dark-invert');\n          } else {\n            document.body.classList.remove('scroll-dark-invert');\n          }\n        });\n      },\n      { threshold: 0.5 }\n    );\n\n    observer.observe(section);\n  });\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 60
      }
    },
