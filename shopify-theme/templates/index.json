    "multicolumn_8k3Nxc": {
      "type": "multicolumn",
      "blocks": {
        "column_KyQBtT": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Vorbereiten.png",
            "title": "<strong>1. Vorbereiten</strong>",
            "text": "<p>Säubere die Wände, Decken oder Fensterrahmen gründlich – trocken, staubfrei und fettfrei. Eine saubere Oberfläche ist die Basis für maximale Haftung und Wirkung.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_rmNPbg": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Streichen.png",
            "title": "<strong>2. Streichen</strong>",
            "text": "<p>Trage <strong>THERMO-COAT</strong> wie eine herkömmliche Innenfarbe auf Wand und Decke auf. Die spezielle Hightech-Beschichtung reflektiert die Wärmestrahlung zurück in den Raum – wie bei einer Thermoskanne.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_UCGRtL": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Abdichten.png",
            "title": "<strong>3. Abdichten</strong>",
            "text": "<p>Klebe <strong>THERMO-SEAL</strong> in Fenster- und Türspalten (1–8 mm). Das transparente Dichtband reduziert Zugluft, Staub und Schall – und sorgt für ein spürbar ruhigeres Raumklima.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_WGWV98": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Sparen.png",
            "title": "<strong>4. Sparen</strong>",
            "text": "<p>Bereits ab dem ersten Tag nach dem Trocknen sinken deine Heiz- und Kühlkosten – um bis zu 42 %. Ohne Baustelle, ohne Lärm – dafür mit sofortiger Wirkung.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
