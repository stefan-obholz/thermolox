{{ 'color-palette.css' | asset_url | stylesheet_tag }}

<div class="color-palette-section page-width" id="everloxx-color-palette">
  <div class="color-palette-inner">

    <!-- Grid (linke Seite) -->
    <div class="cp-grid-wrap">
      <div class="cp-grid" id="cp-grid">
        <div class="cp-loading">Farben werden geladen …</div>
      </div>
    </div>

    <!-- Beschreibung (rechte Seite) -->
    <div class="cp-detail" id="cp-detail" aria-live="polite">
      <p class="cp-detail-hint">Farbe auswählen</p>
    </div>

  </div>
</div>

<script>
(function () {
  const API = 'https://climalox-proxy.stefan-obholz.workers.dev/palette';
  const grid = document.getElementById('cp-grid');
  const detail = document.getElementById('cp-detail');
  let allColors = [];

  function luminance(hex) {
    const r = parseInt(hex.slice(1,3),16)/255;
    const g = parseInt(hex.slice(3,5),16)/255;
    const b = parseInt(hex.slice(5,7),16)/255;
    return 0.2126*r + 0.7152*g + 0.0722*b;
  }

  function textColor(hex) {
    return luminance(hex) > 0.35 ? '#1a1a1a' : '#ffffff';
  }

  function showDetail(color) {
    const fg = luminance(color.hex) > 0.35 ? '#1a1a1a' : '#f5f5f5';
    detail.style.backgroundColor = color.hex;
    detail.style.color = fg;
    detail.innerHTML = `
      <div class="cp-detail-body">
        <h3 class="cp-detail-name" style="color:${fg}">${color.name}</h3>
        <p class="cp-detail-subname" style="color:${fg}">${color.hex}</p>
        <p class="cp-detail-desc" style="color:${fg}">${color.description || ''}</p>
      </div>
    `;
  }

  function renderGrid(colors) {
    // Gruppen ermitteln (in Reihenfolge des ersten Auftretens)
    const groups = [];
    const seen = new Set();
    colors.forEach(c => { if (!seen.has(c.group_name)) { seen.add(c.group_name); groups.push(c.group_name); } });

    grid.innerHTML = '';
    groups.forEach(group => {
      const shades = colors.filter(c => c.group_name === group)
                           .sort((a,b) => a.shade_index - b.shade_index);

      // Group name label
      const label = document.createElement('h3');
      label.className = 'cp-group-name';
      label.textContent = group;
      grid.appendChild(label);

      const row = document.createElement('div');
      row.className = 'cp-row';
      shades.forEach(color => {
        const swatch = document.createElement('button');
        swatch.className = 'cp-swatch';
        swatch.style.background = color.hex;
        swatch.title = color.name;
        swatch.setAttribute('aria-label', `${color.name} ${color.hex}`);
        swatch.addEventListener('click', () => {
          document.querySelectorAll('.cp-swatch.active').forEach(s => s.classList.remove('active'));
          swatch.classList.add('active');
          showDetail(color);
        });
        row.appendChild(swatch);
      });
      grid.appendChild(row);
    });

    // Erste Farbe vorauswählen
    if (colors.length > 0) {
      grid.querySelector('.cp-swatch')?.click();
    }
  }

  fetch(API)
    .then(r => r.json())
    .then(data => {
      allColors = data.colors || [];
      renderGrid(allColors);
    })
    .catch(() => {
      grid.innerHTML = '<p style="color:#999;padding:16px">Farben konnten nicht geladen werden.</p>';
    });
})();
</script>

{% schema %}
{
  "name": "Farbpalette",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Farbpalette"
    }
  ]
}
{% endschema %}
