        },
        "hq4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Was ist THERMO-SEAL?",
            "icon": "question_mark",
            "row_content": "<p>THERMO-SEAL ist unser transparentes Dichtband f\u00fcr Fenster- und T\u00fcrspalten. Es reduziert Zugluft, Staub und L\u00e4rm \u2013 kaum sichtbar, sofort sp\u00fcrbar. Die perfekte Erg\u00e4nzung zu deiner neuen Wandfarbe.</p>"
