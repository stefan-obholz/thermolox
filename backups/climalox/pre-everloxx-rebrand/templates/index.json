nt.getElementById('cx-tab-' + id).style.color = '#fff';\n}\n\ndocument.querySelectorAll('.cx-ba-slider').forEach(function(container) {\n  var clip = container.querySelector('.cx-ba-clip');\n  var handle = container.querySelector('.cx-ba-handle');\n  var dragging = false;\n  function setPos(x) {\n    var rect = container.getBoundingClientRect();\n    var pct = Math.max(0, Math.min(1, (x - rect.left) / rect.width));\n    clip.style.clipPath = 'inset(0 ' + ((1 - pct) * 100) + '% 0 0)';\n    handle.style.left = (pct * 100) + '%';\n  }\n  container.addEventListener('mousedown', function(e) { dragging = true; setPos(e.clientX); e.preventDefault(); });\n  document.addEventListener('mousemove', function(e) { if (dragging) setPos(e.clientX); });\n  document.addEventListener('mouseup', function() { dragging = false; });\n  container.addEventListener('touchstart', function(e) { dragging = true; setPos(e.touches[0].clientX); }, { passive: true });\n  document.addEventListener('touchmove', function(e) { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });\n  document.addEventListener('touchend', function() { dragging = false; });\n});\n</script>",
