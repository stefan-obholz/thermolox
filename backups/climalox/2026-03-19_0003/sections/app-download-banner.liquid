{%- style -%}
  .app-banner {
    text-align: center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .app-banner__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .app-banner__text {
    font-size: 1.1rem;
    max-width: 640px;
    margin: 0 auto 28px;
    opacity: 0.85;
    line-height: 1.6;
  }
  .app-banner__badges {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .app-banner__badges a img {
    height: 52px;
    width: auto;
    transition: transform 0.2s ease;
  }
  .app-banner__badges a:hover img {
    transform: translateY(-2px);
  }
  @media screen and (max-width: 749px) {
    .app-banner__title { font-size: 1.5rem; }
    .app-banner__badges a img { height: 44px; }
  }
{%- endstyle -%}

<div class="app-banner color-{{ section.settings.color_scheme }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="app-banner__title">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.text != blank -%}
    <p class="app-banner__text">{{ section.settings.text }}</p>
  {%- endif -%}

  <div class="app-banner__badges">
    {%- if section.settings.app_store_url != blank -%}
      <a href="{{ section.settings.app_store_url }}" target="_blank" rel="noopener">
        <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg"
             alt="Im App Store laden" loading="lazy">
      </a>
    {%- endif -%}

    {%- if section.settings.play_store_url != blank -%}
      <a href="{{ section.settings.play_store_url }}" target="_blank" rel="noopener">
        <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg"
             alt="Bei Google Play laden" loading="lazy">
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "App Download Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Hol dir die CLIMALOX Design App"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Beschreibung",
      "default": "Farben virtuell an deinen W\u00e4nden testen, Projekte planen und direkt bestellen \u2013 alles in einer App."
    },
    {
      "type": "url",
      "id": "app_store_url",
      "label": "App Store URL"
    },
    {
      "type": "url",
      "id": "play_store_url",
      "label": "Google Play URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "App Download Banner"
    }
  ]
}
{% endschema %}
