    "ev_app_flow": {
      "type": "custom-liquid",
      "name": "App Flow Animation",
      "settings": {
        "custom_liquid": "<style>\n.ev-flow {\n  padding: 100px 20px;\n  background: #1A1614;\n  color: #ffffff;\n  margin-left: calc(-50vw + 50%);\n  margin-right: calc(-50vw + 50%);\n  width: 100vw;\n  overflow: hidden;\n}\n.ev-flow-inner {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n.ev-flow h2 {\n  font-family: 'Times New Roman', Georgia, serif;\n  font-weight: 300;\n  font-size: clamp(2rem, 4vw, 3.5rem);color:#ffffff;\n  text-align: center;\n  margin: 0 0 16px;\n  letter-spacing: -0.01em;\n}\n.ev-flow-sub {\n  text-align: center;\n  color: rgba(255,255,255,0.6);\n  margin-bottom: 64px;\n  font-size: 1.1rem;\n}\n.ev-flow-steps {\n  display: flex;\n  gap: 0;\n  align-items: stretch;\n  position: relative;\n}\n.ev-flow-step {\n  flex: 1;\n  text-align: center;\n  padding: 32px 16px;\n  opacity: 0;\n  transform: translateY(40px);\n  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);\n  position: relative;\n}\n.ev-flow-step.visible {\n  opacity: 1;\n  transform: translateY(0);\n}\n.ev-flow-step:not(:last-child)::after {\n  content: '→';\n  position: absolute;\n  right: -8px;\n  top: 50%;\n  transform: translateY(-50%);\n  color: #efd2a7;\n  font-size: 1.5rem;\n  opacity: 0.5;\n}\n.ev-flow-icon {\n  width: 64px;\n  height: 64px;\n  margin: 0 auto 20px;\n  background: rgba(239,210,167,0.18);\n  border-radius: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.ev-flow-icon svg {\n  width: 28px;\n  height: 28px;\n  stroke: #efd2a7;\n  fill: none;\n  stroke-width: 1.5;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n.ev-flow-title {\n  font-weight: 600;\n  font-size: 1.1rem;\n  margin-bottom: 8px;\n  color: #ffffff;\n}\n.ev-flow-desc {\n  font-size: 1.1rem;\n  color: rgba(255,255,255,0.6);\n  line-height: 1.5;\n}\n.ev-flow-badge {\n  display: inline-block;\n  margin-top: 40px;\n  padding: 8px 20px;\n  border: 1px solid rgba(239,210,167,0.5);background:rgba(239,210,167,0.1);\n  border-radius: 20px;\n  color: #efd2a7;\n  font-size: 1.1rem;\n  letter-spacing: 0.08em;\n}\n@media (max-width: 749px) {\n  .ev-flow-steps { flex-direction: column; gap: 8px; }\n  .ev-flow-step:not(:last-child)::after { content: '↓'; right: auto; top: auto; bottom: -16px; left: 50%; transform: translateX(-50%); }\n}\n<\/style>\n\n<section class=\"ev-flow\">\n  <div class=\"ev-flow-inner\">\n    <h2>Von der App in dein Zuhause<\/h2>\n    <p class=\"ev-flow-sub\">In 5 Schritten zur perfekten Wandfarbe<\/p>\n    <div class=\"ev-flow-steps\" id=\"ev-flow-steps\">\n      <div class=\"ev-flow-step\">\n        <div class=\"ev-flow-icon\"><svg viewBox=\"0 0 24 24\"><rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\" ry=\"2\"\/><line x1=\"12\" y1=\"18\" x2=\"12.01\" y2=\"18\"\/><\/svg><\/div>\n        <div class=\"ev-flow-title\">App öffnen<\/div>\n        <div class=\"ev-flow-desc\">Kostenlos für iOS & Android<\/div>\n      <\/div>\n      <div class=\"ev-flow-step\">\n        <div class=\"ev-flow-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z\"\/><\/svg><\/div>\n        <div class=\"ev-flow-title\">Farbe wählen<\/div>\n        <div class=\"ev-flow-desc\">132 Premium-Farbtöne durchstöbern<\/div>\n      <\/div>\n      <div class=\"ev-flow-step\">\n        <div class=\"ev-flow-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"\/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"\/><\/svg><\/div>\n        <div class=\"ev-flow-title\">AR Vorschau<\/div>\n        <div class=\"ev-flow-desc\">Deine Wand live in der neuen Farbe sehen<\/div>\n      <\/div>\n      <div class=\"ev-flow-step\">\n        <div class=\"ev-flow-icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"9\" cy=\"21\" r=\"1\"\/><circle cx=\"20\" cy=\"21\" r=\"1\"\/><path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"\/><\/svg><\/div>\n        <div class=\"ev-flow-title\">Bestellen<\/div>\n        <div class=\"ev-flow-desc\">Direkt aus der App — versandkostenfrei<\/div>\n      <\/div>\n      <div class=\"ev-flow-step\">\n        <div class=\"ev-flow-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"\/><polyline points=\"9 22 9 12 15 12 15 22\"\/><\/svg><\/div>\n        <div class=\"ev-flow-title\">Genießen<\/div>\n        <div class=\"ev-flow-desc\">Rolle oder Pinsel — sofort wohnbereit<\/div>\n      <\/div>\n    <\/div>\n    <div style=\"text-align:center;\">\n      <span class=\"ev-flow-badge\">Kostenlose App · Keine Verpflichtung<\/span>\n    <\/div>\n  <\/div>\n<\/section>\n\n<script>\n(function(){\n  var steps = document.querySelectorAll('.ev-flow-step');\n  if(!steps.length) return;\n  var observer = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if(e.isIntersecting){\n        var idx = Array.from(steps).indexOf(e.target);\n        setTimeout(function(){ e.target.classList.add('visible'); }, idx * 150);\n      }\n    });\n  }, {threshold: 0.2});\n  steps.forEach(function(s){ observer.observe(s); });\n})();\n<\/script>",
