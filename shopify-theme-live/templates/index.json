    "ev_sticky": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.ev-sticky-cta {\n  position: fixed;\n  bottom: -60px;\n  left: 50%;\n  transform: translateX(-50%);\n  z-index: 999;\n  padding: 14px 40px;\n  background: #2D2926;\n  color: #ffffff;\n  text-decoration: none;\n  font-weight: 600;\n  font-size: 1.1rem;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  border-radius: 40px;\n  box-shadow: 0 4px 20px rgba(0,0,0,0.3);\n  transition: bottom 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;\n  white-space: nowrap;\n}\n.ev-sticky-cta.visible {\n  bottom: 28px;\n}\n.ev-sticky-cta:hover {\n  background: #efd2a7;\n  color: #2D2926;\n}\n<\/style>\n<a href=\"\/collections\/wandfarben\" class=\"ev-sticky-cta\" id=\"ev-sticky-cta\">Farbtöne entdecken<\/a>\n<script>\n(function(){\n  var btn = document.getElementById('ev-sticky-cta');\n  var hero = document.querySelector('.ev-hero');\n  var grid = document.querySelector('[class*=\"product\"]');\n  if(!btn || !hero) return;\n  window.addEventListener('scroll', function(){\n    var heroBottom = hero.getBoundingClientRect().bottom;\n    var gridTop = grid ? grid.getBoundingClientRect().top : 99999;\n    if(heroBottom < 0 && gridTop > 200){\n      btn.classList.add('visible');\n    } else {\n      btn.classList.remove('visible');\n    }\n  }, {passive:true});\n})();\n<\/script>",
