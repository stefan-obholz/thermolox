position:absolute;inset:0;clip-path:inset(0 50% 0 0);\">\n        <img src=\"{{ 'cx-living2-before.png' | asset_url }}\" alt=\"Salon vorher\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 45%;\" loading=\"lazy\">\n      <\/div>\n      <div class=\"cx-ba-handle\" style=\"position:absolute;top:0;bottom:0;width:3px;background:#fff;left:50%;transform:translateX(-50%);z-index:10;pointer-events:none;\">\n        <div style=\"position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:44px;height:44px;border-radius:50%;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,0.3);display:flex;align-items:center;justify-content:center;\">\n          <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#404040\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m18 8 4 4-4 4\"\/><path d=\"m6 8-4 4 4 4\"\/><path d=\"M2 12h20\"\/><\/svg>\n        <\/div>\n      <\/div>\n      <div style=\"position:absolute;bottom:16px;left:16px;background:rgba(0,0,0,0.6);color:#fff;padding:6px 14px;border-radius:20px;font-size:1.1rem;letter-spacing:1px;z-index:5;\">VORHER<\/div>\n      <div style=\"position:absolute;bottom:16px;right:16px;background:rgba(239,187,165,0.9);color:#404040;padding:6px 14px;border-radius:20px;font-size:1.1rem;letter-spacing:1px;font-weight:600;z-index:5;\">Luxury Kaschmirbeige<\/div>\n    <\/div>\n  <\/div>\n<\/section>\n\n<script>\nfunction cxSwitchRoom(id) {\n  document.querySelectorAll('.cx-ba-slider').forEach(function(el) { el.style.display = 'none'; });\n  document.getElementById('cx-slider-' + id).style.display = 'block';\n  document.querySelectorAll('[id^=\"cx-tab-\"]').forEach(function(btn) {\n    btn.style.background = '#fff'; btn.style.color = '#404040';\n  });\n  document.getElementById('cx-tab-' + id).style.background = '#404040';\n  document.getElementById('cx-tab-' + id).style.color = '#fff';\n}\n\ndocument.querySelectorAll('.cx-ba-slider').forEach(function(container) {\n  var clip = container.querySelector('.cx-ba-clip');\n  var handle = container.querySelector('.cx-ba-handle');\n  var dragging = false;\n  function setPos(x) {\n    var rect = container.getBoundingClientRect();\n    var pct = Math.max(0, Math.min(1, (x - rect.left) \/ rect.width));\n    clip.style.clipPath = 'inset(0 ' + ((1 - pct) * 100) + '% 0 0)';\n    handle.style.left = (pct * 100) + '%';\n  }\n  container.addEventListener('mousedown', function(e) { dragging = true; setPos(e.clientX); e.preventDefault(); });\n  document.addEventListener('mousemove', function(e) { if (dragging) setPos(e.clientX); });\n  document.addEventListener('mouseup', function() { dragging = false; });\n  container.addEventListener('touchstart', function(e) { dragging = true; setPos(e.touches[0].clientX); }, { passive: true });\n  document.addEventListener('touchmove', function(e) { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });\n  document.addEventListener('touchend', function() { dragging = false; });\n});\n<\/script>",
