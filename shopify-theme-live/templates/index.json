        "custom_liquid": "<style>\n.ev-app-cta{padding:100px 20px;background:linear-gradient(135deg,#1A1614 0%,#2D2926 100%);color:#fff;margin-left:calc(-50vw + 50%);margin-right:calc(-50vw + 50%);width:100vw;text-align:center;}\n.ev-app-cta h2{font-family:'Times New Roman',Georgia,serif;font-weight:300;font-size:clamp(2rem,4vw,3.2rem);margin:0 0 16px;letter-spacing:-0.01em;color:#ffffff;}\n.ev-app-cta h2 em{color:#efd2a7;font-style:italic;}\n.ev-app-cta p{color:rgba(255,255,255,0.75);max-width:500px;margin:0 auto 40px;line-height:1.6;font-size:1.1rem;}\n.ev-app-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}\n.ev-app-btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.35);border-radius:12px;color:#fff;text-decoration:none;transition:all 0.3s ease;}\n.ev-app-btn:hover{background:rgba(255,255,255,0.2);border-color:rgba(255,255,255,0.4);}\n.ev-app-btn svg{width:24px;height:24px;fill:#fff;}\n.ev-app-btn-text{text-align:left;line-height:1.3;}\n.ev-app-btn-small{font-size:1.1rem;opacity:0.85;display:block;}\n.ev-app-btn-big{font-size:1.1rem;font-weight:600;display:block;}\n<\/style>\n<section class=\"ev-app-cta\">\n<h2>Noch unsicher?<br><em>Probier es an deiner Wand.<\/em><\/h2>\n<p>Lade die EVERLOXX App und sieh deine Lieblingsfarbe live an deiner Wand — mit AR-Vorschau, bevor du bestellst.<\/p>\n<div class=\"ev-app-btns\">\n<a href=\"#\" class=\"ev-app-btn\">\n<svg viewBox=\"0 0 24 24\"><path d=\"M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z\"\/><\/svg>\n<span class=\"ev-app-btn-text\"><span class=\"ev-app-btn-small\">Laden im<\/span><span class=\"ev-app-btn-big\">App Store<\/span><\/span>\n<\/a>\n<a href=\"#\" class=\"ev-app-btn\">\n<svg viewBox=\"0 0 24 24\"><path d=\"M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z\"\/><\/svg>\n<span class=\"ev-app-btn-text\"><span class=\"ev-app-btn-small\">Jetzt bei<\/span><span class=\"ev-app-btn-big\">Google Play<\/span><\/span>\n<\/a>\n<\/div>\n<\/section>",
