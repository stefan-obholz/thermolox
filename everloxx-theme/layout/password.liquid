<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {{ content_for_header }}
  {{ 'everloxx.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --color-bg: #ffffff;
      --color-text: #2D2926;
      --color-accent: #efd2a7;
      --color-dark: #1A1614;
      --color-border: rgba(0,0,0,0.08);
    }
    .password-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px 20px;
      background: var(--color-dark);
      color: #fff;
    }
    .password-page__logo { max-width: 240px; margin-bottom: 32px; }
    .password-page__logo img { width: 100%; height: auto; }
    .password-page__heading { font-size: 2rem; font-weight: 300; margin: 0 0 8px; }
    .password-page__subtext { font-size: 1.1rem; opacity: 0.7; margin-bottom: 32px; }
    .password-page__form { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 360px; }
    .password-page__input {
      padding: 14px 16px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 8px;
      background: rgba(255,255,255,0.08);
      color: #fff;
      font-size: 1rem;
    }
    .password-page__input::placeholder { color: rgba(255,255,255,0.4); }
    .password-page__btn {
      padding: 14px 16px;
      background: var(--color-accent);
      color: var(--color-dark);
      border: none;
      border-radius: 40px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .password-page__btn:hover { opacity: 0.85; }
    .password-page__admin { margin-top: 24px; font-size: 0.85rem; opacity: 0.5; }
    .password-page__admin a { color: var(--color-accent); }
  </style>
</head>
<body>
  <div class="password-page">
    <div class="password-page__logo">
      <img src="{{ 'EVERLOXX_LOGO_WIDE.png' | asset_url }}" alt="EVERLOXX">
    </div>
    <h1 class="password-page__heading">Bald geht es los</h1>
    <p class="password-page__subtext">Unser Shop wird gerade vorbereitet.</p>

    {%- form 'storefront_password' -%}
      <div class="password-page__form">
        {%- if form.errors -%}
          <p style="color:#e55;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <input type="password" name="password" class="password-page__input" placeholder="Passwort eingeben">
        <button type="submit" class="password-page__btn">Shop betreten</button>
      </div>
    {%- endform -%}

    <p class="password-page__admin">
      Bist du der Shop-Inhaber? <a href="/admin">Hier anmelden</a>
    </p>
  </div>

  {{ content_for_layout }}
</body>
</html>
