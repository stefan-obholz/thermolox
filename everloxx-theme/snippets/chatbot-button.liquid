<style>
/* EVERLOXX Chat Button — Ring Icon */
#chat-toggle-btn {
  position: fixed;
  bottom: 28px;
  right: 40px;
  z-index: 999999 !important;
  cursor: pointer;
  width: 128px;
  height: 128px;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  padding: 0;
  transition: opacity .3s ease;
  animation: pulseSoft 2.8s ease-in-out infinite;
}

#chat-toggle-btn::before { display: none; }
#chat-toggle-btn::after { display: none; }

#chat-toggle-btn img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  pointer-events: none;
  filter: drop-shadow(0 2px 16px rgba(0,0,0,0.15));
}

@keyframes pulseSoft {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.07); }
}

/* Hover */
#chat-toggle-btn:hover { animation-play-state: paused; }

/* 📱 Mobile */
@media (max-width: 768px) {
  #chat-toggle-btn {
    width: 100px;
    height: 100px;
    bottom: 20px;
    right: 24px;
  }
}

/* 🔒 Wenn Chat aktiv → Button ausblenden */
body.chat-open #chat-toggle-btn {
  opacity: 0 !important;
  transform: scale(0.85);
  pointer-events: none;
  transition: opacity .25s ease, transform .25s ease;
}

/* 🧠 Overlay + Popup */
#chatbot-overlay {
  position: fixed;
  inset: 0;
  z-index: 9998;
  background: rgba(0,0,0,.45);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity .25s ease;
}
#chatbot-overlay.active {
  opacity: 1;
  pointer-events: auto;
}
#chatbot-popup {
  width: 95%;
  max-width: 800px;
  height: 95%;
  max-height: 800px;
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  transform: translateY(30px);
  transition: transform .25s ease;
  display: flex;
  flex-direction: column;
}
#chatbot-overlay.active #chatbot-popup {
  transform: translateY(0);
}
</style>

<!-- 💬 Chat Button -->
<button id="chat-toggle-btn" aria-label="Chat öffnen">
  <img src="{{ 'EVERLOXX_ICON.png' | asset_url }}" alt="EVERLOXX Chat" loading="lazy">
</button>

<!-- 💭 Overlay + Chatbot -->
<div id="chatbot-overlay" aria-hidden="true">
  <div id="chatbot-popup">
    {% section 'everloxx-chatbot' %}
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded",()=>{
  const btn=document.getElementById("chat-toggle-btn");
  const overlay=document.getElementById("chatbot-overlay");

  function loadAndBootEVERLOXX(){
    if(window.__everloxxBootedOnce||document.getElementById("chat-window")) return;
    window.__everloxxBootedOnce=true;
    const s=document.createElement("script");
    s.src="{{ 'everloxx-chatbot.js' | asset_url }}?v="+Date.now();
    s.async=true;
    s.onload=()=>{
      const evt=new Event("DOMContentLoaded",{bubbles:true,cancelable:true});
      document.dispatchEvent(evt);
      console.log("[EVERLOXX] Chatbot initialisiert.");
    };
    document.body.appendChild(s);
  }

  function openChat(){
    overlay.classList.add("active");
    document.body.classList.add("chat-open");
    setTimeout(loadAndBootEVERLOXX,300);
  }
  function closeChat(){
    overlay.classList.remove("active");
    document.body.classList.remove("chat-open");
  }

  btn.addEventListener("click",()=>overlay.classList.contains("active")?closeChat():openChat());
  overlay.addEventListener("click",(e)=>{if(e.target===overlay)closeChat();});
  document.addEventListener("keydown",(e)=>{
    if(e.key==="Escape"&&overlay.classList.contains("active")) closeChat();
  });
});
</script>