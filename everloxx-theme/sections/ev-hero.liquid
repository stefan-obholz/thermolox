{%- style -%}
.ev-hero {
  position: relative;
  width: 100vw;
  height: 100vh;
  margin-left: calc(-50vw + 50%);
  overflow: hidden;
}
.ev-hero video {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.ev-hero-top-fade {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 150px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.3) 40%, transparent 100%);
  z-index: 2;
  pointer-events: none;
}
.ev-hero-overlay {
  position: absolute;
  top: 0; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.15) 50%, transparent 70%);
  padding: 0 60px 120px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.ev-hero h1 {
  font-family: 'Times New Roman', Georgia, serif;
  font-weight: 300;
  color: #ffffff;
  margin: 0;
  line-height: 1.0;
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  letter-spacing: -0.02em;
}
.ev-hero h1 em {
  font-style: italic;
  font-weight: 300;
}
.ev-hero p {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.7);
  margin: 20px 0 32px;
  max-width: 500px;
  line-height: 1.5;
}
.ev-hero-btn {
  display: inline-block;
  width: fit-content;
  padding: 16px 48px;
  background: #efd2a7;
  color: #2D2926;
  text-decoration: none;
  font-weight: 600;
  font-size: 1.1rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  transition: all 0.4s ease;
  border-radius: 40px;
  border: none;
}
.ev-hero-btn:hover {
  background: #ffffff;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
}
.ev-hero-scroll {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.5);
  font-size: 1.8rem;
  animation: ev-bounce 2s infinite;
}
@keyframes ev-bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}
@media (max-width: 749px) {
  .ev-hero { height: 85vh; }
  .ev-hero-overlay { padding: 0 24px 80px; }
}
{%- endstyle -%}

<div class="ev-hero">
  <div class="ev-hero-top-fade"></div>
  <video autoplay muted loop playsinline>
    <source src="https://cdn.shopify.com/videos/c/o/v/31a8ce5b004e491dbd5a3615c5b917c7.mp4" type="video/mp4">
  </video>
  <div class="ev-hero-overlay">
    <h1>Dein<br><em>Wohlfühl-Zuhause.</em></h1>
    <p>Premium-Wandfarben für Räume, die sich so gut anfühlen, wie sie aussehen.</p>
    <a href="/collections/wandfarben" class="ev-hero-btn">Farbtöne entdecken</a>
  </div>
  <div class="ev-hero-scroll">↓</div>

<script>
(function(){
  const hero = document.querySelector('.ev-hero');
  const vid = hero ? hero.querySelector('video') : null;
  if(!vid) return;
  vid.style.height = '120%';
  vid.style.top = '-10%';
  window.addEventListener('scroll', function(){
    const s = window.scrollY;
    if(s < window.innerHeight * 1.5){
      vid.style.transform = 'translateY(' + (s * 0.3) + 'px)';
    }
  }, {passive:true});
})();
</script>
</div>

{% schema %}
{
  "name": "EVERLOXX Hero",
  "tag": "section",
  "class": "ev-section",
  "settings": []
}
{% endschema %}
