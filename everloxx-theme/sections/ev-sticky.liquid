<style>
.ev-sticky-cta {
  position: fixed;
  bottom: -80px;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0;
  pointer-events: none;
  z-index: 999;
  padding: 14px 40px;
  background: #2D2926;
  color: #ffffff;
  text-decoration: none;
  font-weight: 600;
  font-size: 1.1rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 40px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  transition: bottom 0.4s cubic-bezier(0.16, 1, 0.3, 1),
              background 0.3s ease,
              position 0s,
              box-shadow 0.3s ease;
  white-space: nowrap;
}
.ev-sticky-cta.visible {
  bottom: 28px;
  opacity: 1;
  pointer-events: auto;
}
.ev-sticky-cta.docked {
  position: absolute;
  bottom: auto;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  opacity: 1;
  pointer-events: auto;
}
.ev-sticky-cta:hover {
  background: #efd2a7;
  color: #2D2926;
}
@media (max-width: 749px) {
  .ev-sticky-cta { padding: 12px 28px !important; font-size: 0.9rem !important; }
  .ev-sticky-cta.visible { bottom: 16px !important; }
}
</style>

<a href="/collections/wandfarben" class="ev-sticky-cta" id="ev-sticky-cta">Farbtöne entdecken</a>

<script>
(function(){
  var btn = document.getElementById('ev-sticky-cta');
  if(!btn) return;

  var docked = false;

  window.addEventListener('scroll', function(){
    var dock = document.getElementById('ev-cta-dock-slot');
    var hero = document.querySelector('section[aria-label]');

    if(!hero) return;

    var scrollY = window.scrollY;

    // Show button after 300px scroll
    if(scrollY > 300){
      if(!docked) btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
      if(docked) undock();
      return;
    }

    // Dock when the dock slot is in view
    if(dock){
      var dockRect = dock.getBoundingClientRect();
      var btnHeight = btn.offsetHeight;
      var viewH = window.innerHeight;

      // Button is at bottom:28px → it's at viewH - 28 - btnHeight
      var btnVisualTop = viewH - 28 - btnHeight;

      // If the dock slot center is near the button's position, dock it
      var dockCenter = dockRect.top + dockRect.height / 2;

      if(dockCenter < btnVisualTop + btnHeight && dockCenter > 0 && !docked){
        dockBtn(dock);
      } else if(dockRect.top > viewH && docked){
        /* Only undock when scrolling UP past the dock (dock goes below viewport) */
        undock();
      }
    }
  }, {passive:true});

  function dockBtn(dock){
    docked = true;
    dock.style.position = 'relative';
    btn.classList.remove('visible');
    btn.classList.add('docked');
    dock.appendChild(btn);
  }

  function undock(){
    docked = false;
    btn.classList.remove('docked');
    btn.classList.add('visible');
    document.body.appendChild(btn);
  }

  /* Override: only undock when scrolling ABOVE the dock, not below */
})();
</script>

{% schema %}
{
  "name": "EVERLOXX Sticky Bar",
  "tag": "section",
  "class": "ev-section",
  "settings": []
}
{% endschema %}
