<style>
  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
  }
  .header__mobile-toggle svg { width: 24px; height: 24px; }

  .header__cart-wrap { position: relative; display: inline-flex; }
  .header__cart-badge {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.65rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .header__drawer {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 9998;
  }
  .header__drawer.open { display: flex; }
  .header__drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
  }
  .header__drawer-panel {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 280px;
    max-width: 80vw;
    background: #fff;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 1;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  .header__drawer.open .header__drawer-panel { transform: translateX(0); }
  .header__drawer-close {
    align-self: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
  }
  .header__drawer-close svg { width: 24px; height: 24px; }
  .header__drawer-nav { display: flex; flex-direction: column; gap: 4px; margin-top: 16px; }
  .header__drawer-nav a {
    padding: 12px 0;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .header__drawer-nav a:hover { color: var(--color-accent); }

  @media (max-width: 749px) {
    .header__mobile-toggle { display: block; }
    .header__nav { display: none !important; }
    .header__search { display: none; }
  }
</style>

<header class="header">
  <div class="page-width">
    <div class="header__inner">
      <button class="header__mobile-toggle" id="ev-mobile-toggle" aria-label="Menue oeffnen">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <a href="/" class="header__logo">
        <img src="{{ 'EVERLOXX_LOGO_WIDE.png' | asset_url }}" alt="EVERLOXX" loading="eager">
      </a>

      <div class="header__search">
        <form action="{{ routes.search_url }}" method="get" class="header__search-form">
          <input
            type="search"
            name="q"
            class="header__search-input"
            placeholder="Produkte durchsuchen..."
            value="{{ search.terms | escape }}"
          >
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit" class="header__search-btn" aria-label="Suchen">
            <svg viewBox="0 0 18 19" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 1 1 2.85 3.5a5.784 5.784 0 0 1 8.18 8.18m.26 1.12a6.78 6.78 0 1 1 .72-.7l5.4 5.4a.5.5 0 1 1-.71.7z" clip-rule="evenodd"/></svg>
          </button>
        </form>
      </div>

      <div class="header__icons">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon" aria-label="Konto">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="header__icon header__cart-wrap" aria-label="Warenkorb">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

      <nav class="header__nav" aria-label="Hauptnavigation">
        {%- for link in linklists.main-menu.links -%}
          <a href="{{ link.url }}" class="header__nav-link{% if link.active %} active{% endif %}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div class="header__drawer" id="ev-mobile-drawer">
  <div class="header__drawer-overlay" id="ev-drawer-overlay"></div>
  <div class="header__drawer-panel">
    <button class="header__drawer-close" id="ev-drawer-close" aria-label="Menue schliessen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav class="header__drawer-nav" aria-label="Mobile Navigation">
      {%- for link in linklists.main-menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">Konto</a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}">Warenkorb{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a>
    </nav>
  </div>
</div>

<script>
(function(){
  var toggle = document.getElementById('ev-mobile-toggle');
  var drawer = document.getElementById('ev-mobile-drawer');
  var close = document.getElementById('ev-drawer-close');
  var overlay = document.getElementById('ev-drawer-overlay');
  function open(){ drawer.classList.add('open'); document.body.style.overflow='hidden'; }
  function shut(){ drawer.classList.remove('open'); document.body.style.overflow=''; }
  if(toggle) toggle.addEventListener('click', open);
  if(close) close.addEventListener('click', shut);
  if(overlay) overlay.addEventListener('click', shut);
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
