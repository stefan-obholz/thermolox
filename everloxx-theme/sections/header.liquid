<style>
  /* Predictive Search */
  .header__search-form { position: relative; }
  .ev-search-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    border-radius: var(--radius-sm, 8px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    z-index: 100;
    max-height: 400px;
    overflow-y: auto;
    margin-top: 4px;
  }
  .ev-search-dropdown.open { display: block; }
  .ev-search-result {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    text-decoration: none;
    color: var(--color-text, #2D2926);
    transition: background 0.15s;
    cursor: pointer;
  }
  .ev-search-result:hover { background: var(--gray-50, #FAFAF9); }
  .ev-search-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(0,0,0,0.08);
  }
  .ev-search-img {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .ev-search-name {
    font-size: 0.95rem;
    font-weight: 500;
    flex: 1;
  }
  .ev-search-empty {
    padding: 16px;
    text-align: center;
    color: var(--gray-400, #A8A29E);
    font-size: 0.9rem;
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
  }
  .header__mobile-toggle svg { width: 24px; height: 24px; }

  .header__cart-wrap { position: relative; display: inline-flex; }
  .header__cart-badge {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.65rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .header__drawer {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 9998;
  }
  .header__drawer.open { display: flex; }
  .header__drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
  }
  .header__drawer-panel {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 280px;
    max-width: 80vw;
    background: #fff;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 1;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  .header__drawer.open .header__drawer-panel { transform: translateX(0); }
  .header__drawer-close {
    align-self: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
  }
  .header__drawer-close svg { width: 24px; height: 24px; }
  .header__drawer-nav { display: flex; flex-direction: column; gap: 4px; margin-top: 16px; }
  .header__drawer-nav a {
    padding: 12px 0;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .header__drawer-nav a:hover { color: var(--color-accent); }

  @media (max-width: 749px) {
    .header__mobile-toggle { display: block; }
    .header__nav { display: none !important; }
    .header__search { display: none; }
  }
</style>

<header class="header">
  <div class="page-width">
    <div class="header__inner">
      <button class="header__mobile-toggle" id="ev-mobile-toggle" aria-label="Menue oeffnen">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <a href="/" class="header__logo">
        <img src="{{ 'EVERLOXX_LOGO_WIDE.png' | asset_url }}" alt="EVERLOXX" loading="eager">
      </a>

      <div class="header__search">
        <form action="{{ routes.search_url }}" method="get" class="header__search-form" id="ev-search-form">
          <input
            type="search"
            name="q"
            class="header__search-input"
            id="ev-search-input"
            placeholder="Produkte durchsuchen..."
            value="{{ search.terms | escape }}"
            autocomplete="off"
          >
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit" class="header__search-btn" aria-label="Suchen">
            <svg viewBox="0 0 18 19" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 1 1 2.85 3.5a5.784 5.784 0 0 1 8.18 8.18m.26 1.12a6.78 6.78 0 1 1 .72-.7l5.4 5.4a.5.5 0 1 1-.71.7z" clip-rule="evenodd"/></svg>
          </button>
          <div class="ev-search-dropdown" id="ev-search-dropdown"></div>
        </form>
      </div>

      <div class="header__icons">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon" aria-label="Konto">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="header__icon header__cart-wrap" aria-label="Warenkorb">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

      <nav class="header__nav" aria-label="Hauptnavigation">
        {%- for link in linklists.main-menu.links -%}
          <a href="{{ link.url }}" class="header__nav-link{% if link.active or link.child_active %} active{% endif %}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div class="header__drawer" id="ev-mobile-drawer">
  <div class="header__drawer-overlay" id="ev-drawer-overlay"></div>
  <div class="header__drawer-panel">
    <button class="header__drawer-close" id="ev-drawer-close" aria-label="Menue schliessen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav class="header__drawer-nav" aria-label="Mobile Navigation">
      {%- for link in linklists.main-menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">Konto</a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}">Warenkorb{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a>
    </nav>
  </div>
</div>

<script>
(function(){
  var toggle = document.getElementById('ev-mobile-toggle');
  var drawer = document.getElementById('ev-mobile-drawer');
  var close = document.getElementById('ev-drawer-close');
  var overlay = document.getElementById('ev-drawer-overlay');
  function open(){ drawer.classList.add('open'); document.body.style.overflow='hidden'; }
  function shut(){ drawer.classList.remove('open'); document.body.style.overflow=''; }
  if(toggle) toggle.addEventListener('click', open);
  if(close) close.addEventListener('click', shut);
  if(overlay) overlay.addEventListener('click', shut);
})();

/* Active nav link highlight */
(function(){
  var path = window.location.pathname;
  document.querySelectorAll('.header__nav-link').forEach(function(link){
    var href = link.getAttribute('href');
    if(!href) return;
    /* Exact match or path starts with link href (for collections/products) */
    if(path === href || (href !== '/' && path.startsWith(href))){
      link.classList.add('active');
    }
  });
})();
</script>

<script>
(function(){
  var input = document.getElementById('ev-search-input');
  var dropdown = document.getElementById('ev-search-dropdown');
  if (!input || !dropdown) return;

  var debounceTimer;
  var supaUrl = 'https://xivtfgyvpqckfwwyloub.supabase.co/rest/v1/';
  var supaKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhpdnRmZ3l2cHFja2Z3d3lsb3ViIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjYyNDMwODQsImV4cCI6MjA4MTgxOTA4NH0.WzyDxlU_CnpLaTkKwv8ixgW5IwzC8mEcH6jZmfU27AU';

  function toHandle(name) {
    return name.toLowerCase().replace(/[^a-z0-9äöüß]+/g, '-').replace(/^-|-$/g, '');
  }

  function doSearch(query) {
    if (query.length < 2) {
      dropdown.classList.remove('open');
      return;
    }
    var url = supaUrl + 'palette_colors?name=ilike.*' + encodeURIComponent(query) + '*&select=name,hex,image_url_1&status=eq.active&limit=6';
    fetch(url, {
      headers: { 'apikey': supaKey, 'Authorization': 'Bearer ' + supaKey }
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (!data || !data.length) {
        dropdown.innerHTML = '<div class="ev-search-empty">Keine Ergebnisse</div>';
        dropdown.classList.add('open');
        return;
      }
      var html = '';
      data.forEach(function(p){
        var handle = toHandle(p.name);
        html += '<a href="/products/' + handle + '" class="ev-search-result">'
          + '<span class="ev-search-dot" style="background:' + (p.hex || '#ccc') + ';"></span>'
          + (p.image_url_1 ? '<img class="ev-search-img" src="' + p.image_url_1 + '" alt="" loading="lazy">' : '')
          + '<span class="ev-search-name">' + p.name + '</span>'
          + '</a>';
      });
      dropdown.innerHTML = html;
      dropdown.classList.add('open');
    })
    .catch(function(){ dropdown.classList.remove('open'); });
  }

  input.addEventListener('keyup', function(){
    clearTimeout(debounceTimer);
    var q = input.value.trim();
    debounceTimer = setTimeout(function(){ doSearch(q); }, 300);
  });

  input.addEventListener('focus', function(){
    if (input.value.trim().length >= 2 && dropdown.innerHTML) {
      dropdown.classList.add('open');
    }
  });

  document.addEventListener('click', function(e){
    if (!e.target.closest('#ev-search-form')) {
      dropdown.classList.remove('open');
    }
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
