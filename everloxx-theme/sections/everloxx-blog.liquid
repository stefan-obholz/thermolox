{%- style -%}
  .ev-blog-hero {
    background: var(--gray-50);
    padding: var(--space-10) var(--space-5) var(--space-8);
    text-align: center;
  }
  .ev-blog-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }
  .ev-blog-hero p {
    color: var(--color-text-light);
    font-size: var(--text-md);
    max-width: 560px;
    margin: 0 auto;
  }
  .ev-blog-listing {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-6) var(--space-5) var(--space-10);
  }
  .ev-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .ev-blog-card {
    background: var(--color-bg);
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    display: flex;
    flex-direction: column;
  }
  .ev-blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .ev-blog-card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--gray-50);
  }
  .ev-blog-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .ev-blog-card:hover .ev-blog-card-img img {
    transform: scale(1.04);
  }
  .ev-blog-card-body {
    padding: var(--space-4) var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ev-blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-bottom: var(--space-3);
  }
  .ev-blog-card-tag {
    display: inline-block;
    background: rgba(239,210,167,0.15);
    color: var(--color-text);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .ev-blog-card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-md);
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }
  .ev-blog-card-title a {
    color: inherit;
    text-decoration: none;
  }
  .ev-blog-card-title a:hover {
    color: var(--color-accent);
  }
  .ev-blog-card-excerpt {
    color: var(--color-text-light);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    flex: 1;
  }
  .ev-blog-card-link {
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .ev-blog-card-link:hover {
    color: var(--color-accent);
    gap: var(--space-3);
  }
  .ev-blog-pagination {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-6) 0 var(--space-10);
  }
  .ev-blog-pagination a,
  .ev-blog-pagination span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }
  .ev-blog-pagination a {
    color: var(--color-text);
    border: 1px solid var(--gray-200);
  }
  .ev-blog-pagination a:hover {
    background: var(--color-dark);
    color: #fff;
    border-color: var(--color-dark);
  }
  .ev-blog-pagination span.current {
    background: var(--color-dark);
    color: #fff;
  }
  .ev-blog-pagination span.dots {
    border: none;
    color: var(--gray-400);
  }
  .ev-blog-pagination .ev-page-arrow {
    width: auto;
    padding: 0 var(--space-4);
    border-radius: var(--radius-full);
    font-weight: 600;
  }
  @media (max-width: 989px) {
    .ev-blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 549px) {
    .ev-blog-grid { grid-template-columns: 1fr; }
    .ev-blog-hero { padding: var(--space-8) var(--space-4) var(--space-6); }
  }
{%- endstyle -%}

<div class="ev-blog-hero">
  <h1 class="reveal">{{ blog.title }}</h1>
  <p class="reveal">Inspiration, Tipps und Neuigkeiten rund um Farbe und Wohndesign.</p>
</div>

<div class="ev-blog-listing">
  {%- paginate blog.articles by 12 -%}
    <div class="ev-blog-grid reveal-stagger">
      {%- for article in blog.articles -%}
        <article class="ev-blog-card">
          <a href="{{ article.url }}" class="ev-blog-card-img">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                loading="lazy"
                width="800"
                height="533"
              >
            {%- endif -%}
          </a>
          <div class="ev-blog-card-body">
            {%- if article.tags.size > 0 -%}
              <div class="ev-blog-card-tags">
                {%- for tag in article.tags -%}
                  <span class="ev-blog-card-tag">{{ tag }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
            <h2 class="ev-blog-card-title">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h2>
            {%- if article.excerpt_or_content != blank -%}
              <p class="ev-blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
            {%- endif -%}
            <a href="{{ article.url }}" class="ev-blog-card-link">Weiterlesen &rarr;</a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="ev-blog-pagination" aria-label="Seitennavigation">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="ev-page-arrow">&larr; Zurück</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            {%- if part.title == paginate.current_page -%}
              <span class="current">{{ part.title }}</span>
            {%- else -%}
              <span class="dots">{{ part.title }}</span>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="ev-page-arrow">Weiter &rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "EVERLOXX Blog",
  "tag": "section",
  "settings": []
}
{% endschema %}
