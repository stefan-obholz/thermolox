<style>
@media (max-width: 749px) {
  .ev-customer-form { padding: 32px 16px !important; max-width: 100% !important; }
}
</style>
<div class="section">
  <div class="page-width ev-customer-form" style="max-width:480px;margin:0 auto;padding:60px 20px;">
    <h1 style="text-align:center;margin-bottom:8px;">Passwort zuruecksetzen</h1>
    <p style="text-align:center;color:var(--color-text-light);margin-bottom:24px;">Gib dein neues Passwort ein.</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div style="background:#fef2f2;border:1px solid #e55;padding:12px 16px;border-radius:8px;margin-bottom:16px;color:#c33;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div style="display:flex;flex-direction:column;gap:16px;">
        <label for="ResetPassword" class="visually-hidden">Neues Passwort</label>
        <input type="password" id="ResetPassword" name="customer[password]" autocomplete="new-password" placeholder="Neues Passwort" required
          style="padding:14px 16px;border:1px solid var(--color-border);border-radius:8px;font-size:1rem;">

        <label for="ResetPasswordConfirm" class="visually-hidden">Passwort bestaetigen</label>
        <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" autocomplete="new-password" placeholder="Passwort bestaetigen" required
          style="padding:14px 16px;border:1px solid var(--color-border);border-radius:8px;font-size:1rem;">

        <button type="submit" class="btn btn--primary" style="width:100%;">Passwort speichern</button>
      </div>
    {%- endform -%}

    <div style="text-align:center;margin-top:16px;">
      <a href="{{ routes.account_login_url }}" style="color:var(--color-text-light);font-size:0.95rem;">Zurueck zur Anmeldung</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Passwort zuruecksetzen",
  "settings": []
}
{% endschema %}
