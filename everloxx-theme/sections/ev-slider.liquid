<script>
function cxSwitchRoom(id) {
  document.querySelectorAll('.cx-ba-slider').forEach(function(el) { el.style.display = 'none'; });
  document.getElementById('cx-slider-' + id).style.display = 'block';
  document.querySelectorAll('[id^="cx-tab-"]').forEach(function(btn) {
    btn.style.background = '#fff'; btn.style.color = '#404040';
  });
  document.getElementById('cx-tab-' + id).style.background = '#404040';
  document.getElementById('cx-tab-' + id).style.color = '#fff';
}

document.querySelectorAll('.cx-ba-slider').forEach(function(container) {
  var clip = container.querySelector('.cx-ba-clip');
  var handle = container.querySelector('.cx-ba-handle');
  var dragging = false;
  function setPos(x) {
    var rect = container.getBoundingClientRect();
    var pct = Math.max(0, Math.min(1, (x - rect.left) / rect.width));
    clip.style.clipPath = 'inset(0 ' + ((1 - pct) * 100) + '% 0 0)';
    handle.style.left = (pct * 100) + '%';
  }
  container.addEventListener('mousedown', function(e) { dragging = true; setPos(e.clientX); e.preventDefault(); });
  document.addEventListener('mousemove', function(e) { if (dragging) setPos(e.clientX); });
  document.addEventListener('mouseup', function() { dragging = false; });
  container.addEventListener('touchstart', function(e) { dragging = true; setPos(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchmove', function(e) { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchend', function() { dragging = false; });
});
</script>

