<style>
@media (max-width: 749px) {
  .ev-customer-form { padding: 32px 16px !important; max-width: 100% !important; }
}
</style>
<div class="section">
  <div class="page-width ev-customer-form" style="max-width:480px;margin:0 auto;padding:60px 20px;">
    <h1 style="text-align:center;margin-bottom:24px;">Anmelden</h1>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div style="background:#fef2f2;border:1px solid #e55;padding:12px 16px;border-radius:8px;margin-bottom:16px;color:#c33;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div style="display:flex;flex-direction:column;gap:16px;">
        <label for="CustomerEmail" class="visually-hidden">E-Mail</label>
        <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" placeholder="E-Mail-Adresse" required
          style="padding:14px 16px;border:1px solid var(--color-border);border-radius:8px;font-size:1rem;">

        <label for="CustomerPassword" class="visually-hidden">Passwort</label>
        <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" placeholder="Passwort" required
          style="padding:14px 16px;border:1px solid var(--color-border);border-radius:8px;font-size:1rem;">

        <button type="submit" class="btn btn--primary" style="width:100%;">Anmelden</button>
      </div>
    {%- endform -%}

    <div style="text-align:center;margin-top:24px;font-size:0.95rem;">
      <a href="{{ routes.account_recover_url }}" style="color:var(--color-text-light);">Passwort vergessen?</a>
    </div>
    <div style="text-align:center;margin-top:12px;font-size:0.95rem;">
      Noch kein Konto? <a href="{{ routes.account_register_url }}" style="color:var(--color-accent);font-weight:600;">Registrieren</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Kunden-Login",
  "settings": []
}
{% endschema %}
