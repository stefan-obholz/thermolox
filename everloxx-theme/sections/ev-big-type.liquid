<style>
@media (max-width: 749px) {
  .ev-big-type { padding: 60px 16px !important; }
  .ev-big-type h2 { font-size: clamp(2rem, 10vw, 3.5rem) !important; }
  .ev-big-type p { font-size: 1rem !important; margin-top: 24px !important; }
}
</style>
<section class="ev-big-type" style="background:#000;padding:120px 20px;overflow:hidden;" aria-label="Statement">
  <div style="max-width:1400px;margin:0 auto;">
    <h2 class="cx-section-heading reveal-blur" style="color:#fff !important;font-size:clamp(3rem,8vw,7rem) !important;line-height:1.0 !important;letter-spacing:-0.04em !important;margin:0 !important;">
      Farbe, die<br>
      <span style="color:#efd2a7;">mehr</span> kann
    </h2>
    <p style="color:rgba(255,255,255,0.4);font-size:1.1rem;max-width:480px;margin-top:40px;line-height:1.7;">
      Jeder Anstrich reflektiert Wärmestrahlung zurück in den Raum – für ein Zuhause, das genauso gut aussieht, wie es sich anfühlt
    </p>
  </div>
</section>

{% schema %}
{
  "name": "EVERLOXX Big Type",
  "tag": "section",
  "class": "ev-section",
  "settings": []
}
{% endschema %}
