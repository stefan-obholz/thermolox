{%- style -%}
.cx-product-card {
  transition: background-color 0.4s ease, transform 0.3s ease, box-shadow 0.3s ease;
}
.cx-product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.1);
}
{%- endstyle -%}

