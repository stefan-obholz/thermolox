{% comment %}
  EVERLOXX Custom Product Section
  Replaces Dawn default main-product with a designed layout
{% endcomment %}

{%- style -%}
  .ev-product { max-width: 1200px; margin: 0 auto; padding: 40px 20px 0; }
  .ev-product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  
  /* Image gallery */
  .ev-product-media { position: sticky; top: 100px; }
  .ev-product-main-image { width: 100%; aspect-ratio: 1/1; border-radius: 16px; overflow: hidden; background: transparent; }
  .ev-product-main-image img { width: 100%; height: 100%; object-fit: contain; }
  .ev-product-thumbs { display: flex; gap: 8px; margin-top: 12px; }
  .ev-product-thumb { width: 72px; height: 72px; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; transition: border-color 0.2s; }
  .ev-product-thumb.active, .ev-product-thumb:hover { border-color: #efd2a7; }
  .ev-product-thumb img { width: 100%; height: 100%; object-fit: cover; }
  
  /* Color swatch preview */
  .ev-color-swatch { width: 48px; height: 48px; border-radius: 50%; border: 3px solid #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 16px; }
  
  /* Product info */
  .ev-product-info { padding-top: 8px; }
  .ev-product-collection { font-size: 1.1rem; letter-spacing: 0.12em; text-transform: uppercase; color: #efd2a7; margin-bottom: 8px; font-weight: 600; }
  .ev-product-title { font-family: 'Times New Roman', Georgia, serif; font-weight: 300; font-size: clamp(2rem, 3vw, 2.8rem); color: #2D2926; margin: 0 0 8px; line-height: 1.1; }
  .ev-product-price { font-size: 1.5rem; font-weight: 600; color: #2D2926; margin-bottom: 24px; }
  .ev-product-price small { font-size: 1.1rem; font-weight: 400; color: #999; }
  
  /* Description without bullet points */
  .ev-product-desc { margin-bottom: 32px; }
  .ev-product-desc ul { list-style: none; padding: 0; margin: 0; }
  .ev-product-desc li { padding: 8px 0; border-bottom: 1px solid #f0f0f0; font-size: 1.1rem; color: #555; line-height: 1.5; }
  .ev-product-desc li:last-child { border-bottom: none; }
  .ev-product-desc p { font-size: 1.1rem; color: #555; line-height: 1.6; margin: 0 0 12px; }
  .ev-product-desc strong { color: #2D2926; }
  
  /* Buy section */
  .ev-buy-section { background: #FFF8F5; border-radius: 16px; padding: 24px; margin-bottom: 24px; }
  .ev-quantity-row { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
  .ev-quantity-input { display: flex; align-items: center; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; }
  .ev-quantity-input button { width: 40px; height: 40px; border: none; background: none; font-size: 1.2rem; cursor: pointer; color: #2D2926; }
  .ev-quantity-input button:hover { background: #f0f0f0; }
  .ev-quantity-input input { width: 48px; height: 40px; border: none; text-align: center; font-size: 1.1rem; background: none; }
  .ev-add-to-cart { width: 100%; padding: 16px; background: #2D2926; color: #fff; border: none; border-radius: 40px; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s; letter-spacing: 0.05em; }
  .ev-add-to-cart:hover { background: #efd2a7; color: #2D2926; }
  
  /* Trust row */
  .ev-product-trust { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 32px; }
  .ev-product-trust-item { display: flex; align-items: center; gap: 6px; font-size: 1.1rem; color: #888; }
  .ev-product-trust-item svg { width: 16px; height: 16px; stroke: #efd2a7; fill: none; stroke-width: 1.5; }
  
  /* Wall preview + AR CTA */
  .ev-wall-preview { border-radius: 12px; overflow: hidden; margin-bottom: 24px; }
  .ev-wall-surface { height: 140px; cursor: pointer; background: #ddd; transition: background-color 0.3s; }
  .ev-wall-surface:hover { opacity: 0.92; }
  .ev-ar-inline { display: flex; align-items: center; gap: 16px; padding: 20px; background: #1A1614; }
  .ev-ar-inline svg { width: 28px; height: 28px; stroke: #efd2a7; fill: none; stroke-width: 1.5; flex-shrink: 0; }
  .ev-ar-inline-text { color: #fff; font-size: 1.1rem; line-height: 1.4; }
  .ev-ar-inline-text strong { color: #efd2a7; }
  .ev-ar-inline-text a { color: #efd2a7; text-decoration: underline; }
  .ev-fullscreen-overlay { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9999; background: #ddd; align-items: center; justify-content: center; cursor: pointer; flex-direction: column; gap: 16px; }
  .ev-fullscreen-name { font-size: 2rem; font-weight: 300; letter-spacing: 0.05em; font-family: var(--font-heading-family); }
  .ev-fullscreen-hint { font-size: 1.1rem; opacity: 0.5; }
  
  /* Accordion for tech details */
  .ev-accordion { border-top: 1px solid #eee; }
  .ev-accordion-item { border-bottom: 1px solid #eee; }
  .ev-accordion-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; cursor: pointer; font-weight: 500; font-size: 1.1rem; color: #2D2926; }
  .ev-accordion-header svg { width: 16px; height: 16px; stroke: #999; fill: none; stroke-width: 2; transition: transform 0.3s; }
  .ev-accordion-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .ev-accordion-body-inner { padding: 0 0 16px; font-size: 1.1rem; color: #666; line-height: 1.6; }
  .ev-accordion-item.open .ev-accordion-body { max-height: 500px; }
  .ev-accordion-item.open .ev-accordion-header svg { transform: rotate(180deg); }
  
  /* SEO Schema */
  
  @media (max-width: 749px) {
    .ev-product-grid { grid-template-columns: 1fr; gap: 24px; }
    .ev-product-media { position: static; }
  }
{%- endstyle -%}

<div class="ev-product" itemscope itemtype="https://schema.org/Product">
  <div class="ev-product-grid">
    
    <!-- LEFT: Media -->
    <div class="ev-product-media">
      <div class="ev-product-main-image" id="ev-main-image">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" id="ev-main-img" itemprop="image">
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="ev-product-thumbs">
          {%- for image in product.images -%}
            <div class="ev-product-thumb {% if forloop.first %}active{% endif %}" data-full-src="{{ image | image_url: width: 1200 }}">
              <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}" loading="lazy">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
    
    <!-- RIGHT: Info -->
    <div class="ev-product-info">
      
      {%- if product.type != blank -%}
        <div class="ev-product-collection">{{ product.type }}</div>
      {%- endif -%}
      
      <h1 class="ev-product-title" itemprop="name">{{ product.title }}</h1>
      
      <div class="ev-product-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        {{ product.price | money }}
        <small>inkl. MwSt.</small>
        <meta itemprop="price" content="{{ product.price | money_without_currency | strip_html }}">
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta itemprop="availability" content="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
        <link itemprop="url" href="{{ shop.url }}{{ product.url }}">
      </div>
      
      <!-- DEBUG: Test color surface -->
      <div style="height: 100px; background: red; margin-bottom: 16px; border-radius: 12px;"></div>

      <!-- Description -->
      <div class="ev-product-desc" itemprop="description">
        {{ product.description }}
      </div>

      <!-- Wall Color Preview + AR CTA -->
      <div class="ev-wall-preview" id="ev-wall-preview">
        <div class="ev-wall-surface" id="ev-wall-surface" style="background: #C9B599; height: 140px;" onclick="document.getElementById('ev-fullscreen-color').style.display='flex';"></div>
        <div class="ev-ar-inline">
          <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          <div class="ev-ar-inline-text">
            <strong>Wie sieht das an deiner Wand aus?</strong><br>
            <a href="#">In der EVERLOXX App testen</a>
          </div>
        </div>
      </div>

      <!-- Fullscreen Color Overlay -->
      <div id="ev-fullscreen-color" class="ev-fullscreen-overlay" onclick="this.style.display='none';">
        <span class="ev-fullscreen-name" id="ev-fullscreen-label"></span>
        <span class="ev-fullscreen-hint">Tippe zum Schlie&szlig;en</span>
      </div>
      
      <!-- Buy section -->
      <div class="ev-buy-section">
        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div class="ev-quantity-row">
            <div class="ev-quantity-input">
              <button type="button" onclick="var i=this.nextElementSibling;i.value=Math.max(1,parseInt(i.value)-1);">-</button>
              <input type="number" name="quantity" value="1" min="1" max="99">
              <button type="button" onclick="var i=this.previousElementSibling;i.value=Math.min(99,parseInt(i.value)+1);">+</button>
            </div>
            <span style="font-size:1.1rem;color:#999;">{{ product.selected_or_first_available_variant.title }}</span>
          </div>
          <button type="submit" class="ev-add-to-cart" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}
          </button>
        {%- endform -%}
      </div>
      
      <!-- Trust badges -->
      <div class="ev-product-trust">
        <div class="ev-product-trust-item"><svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Lösemittelfrei</div>
        <div class="ev-product-trust-item"><svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>Kostenloser Versand ab 99€</div>
        <div class="ev-product-trust-item"><svg viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>30 Tage Rückgabe</div>
      </div>
      
      <!-- Accordion -->
      <div class="ev-accordion">
        <div class="ev-accordion-item">
          <div class="ev-accordion-header" onclick="this.parentElement.classList.toggle('open');">
            Technische Details
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="ev-accordion-body"><div class="ev-accordion-body-inner">
            Ergiebigkeit: 6-8 m² pro Liter<br>
            Trocknungszeit: 4-6 Stunden<br>
            Oberfläche: Samtmatt mit seidigem Finish<br>
            Anstrich: 2 Anstriche empfohlen<br>
            Geeignet für: Innenwände, Decken, Gipskarton, Raufaser
          </div></div>
        </div>
        <div class="ev-accordion-item">
          <div class="ev-accordion-header" onclick="this.parentElement.classList.toggle('open');">
            Inhaltsstoffe & Zertifizierung
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="ev-accordion-body"><div class="ev-accordion-body-inner">
            Lösemittelfrei, geruchsarm, allergikerfreundlich.<br>
            Wasserbasierte Dispersionsfarbe mit Klimatechnologie.<br>
            Reflektiert bis zu 50% der Wärmestrahlung.
          </div></div>
        </div>
        <div class="ev-accordion-item">
          <div class="ev-accordion-header" onclick="this.parentElement.classList.toggle('open');">
            Versand & Rückgabe
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="ev-accordion-body"><div class="ev-accordion-body-inner">
            Kostenloser Versand ab 99€ Bestellwert.<br>
            Lieferung in 3-5 Werktagen.<br>
            30 Tage Rückgaberecht bei ungeöffneter Ware.
          </div></div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<!-- SEO: JSON-LD Product Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "image": {{ product.featured_image | image_url: width: 1200 | json }},
  "brand": {
    "@type": "Brand",
    "name": "EVERLOXX"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": "{{ product.price | money_without_currency | strip_html }}",
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": "EVERLOXX"
    }
  }
}
</script>

<script>
(function() {
  var pid = 'gid://shopify/Product/' + {{ product.id | json }};
  var url = 'https://xivtfgyvpqckfwwyloub.supabase.co/rest/v1/palette_colors?shopify_product_id=eq.' + encodeURIComponent(pid) + '&select=hex,name&limit=1';
  var key = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhpdnRmZ3l2cHFja2Z3d3lsb3ViIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjYyNDMwODQsImV4cCI6MjA4MTgxOTA4NH0.WzyDxlU_CnpLaTkKwv8ixgW5IwzC8mEcH6jZmfU27AU';
  fetch(url, { headers: { 'apikey': key, 'Authorization': 'Bearer ' + key } })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d && d.length && d[0].hex) {
        var h = d[0].hex;
        var n = d[0].name || {{ product.title | json }};
        var s = document.getElementById('ev-wall-surface');
        var f = document.getElementById('ev-fullscreen-color');
        var l = document.getElementById('ev-fullscreen-label');
        if (s) s.style.backgroundColor = h;
        if (f) f.style.backgroundColor = h;
        if (l) l.textContent = n;
        var lum = parseInt(h.slice(1,3),16)*0.299 + parseInt(h.slice(3,5),16)*0.587 + parseInt(h.slice(5,7),16)*0.114;
        var tc = lum > 150 ? 'rgba(0,0,0,0.6)' : 'rgba(255,255,255,0.7)';
        if (l) l.style.color = tc;
        if (l && l.nextElementSibling) l.nextElementSibling.style.color = tc;
      }
    }).catch(function(){});
})();
</script>

<script>
(function(){
  var thumbs = document.querySelectorAll('.ev-product-thumb');
  var mainImg = document.getElementById('ev-main-img');
  thumbs.forEach(function(thumb){
    thumb.addEventListener('click', function(){
      if(mainImg) mainImg.src = this.getAttribute('data-full-src');
      thumbs.forEach(function(t){ t.classList.remove('active'); });
      this.classList.add('active');
    });
  });
})();
</script>

{% schema %}
{
  "name": "EVERLOXX Produkt",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
