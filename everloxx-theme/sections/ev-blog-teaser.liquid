<style>
  .ev-blog-card {
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease;
  }
  .ev-blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.1);
  }
  .ev-blog-card:hover svg {
    transform: scale(1.15);
    transition: transform 0.4s ease;
  }
  .ev-blog-card svg {
    transition: transform 0.4s ease;
  }
  @media (max-width: 749px) {
    .ev-blog-teaser-section { padding: 40px 16px !important; }
    .ev-blog-teaser-section > div { max-width: 100% !important; }
    .ev-blog-teaser-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
    .ev-blog-teaser-header { flex-direction: column !important; align-items: flex-start !important; gap: 8px !important; margin-bottom: 24px !important; }
  }
</style>
