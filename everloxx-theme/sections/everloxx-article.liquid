{%- style -%}
  .ev-article {
    max-width: 780px;
    margin: 0 auto;
    padding: var(--space-10) var(--space-5) var(--space-12);
  }
  .ev-article-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .ev-article-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }
  .ev-article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--color-text-light);
    font-size: var(--text-sm);
  }
  .ev-article-meta-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gray-300);
  }
  .ev-article-featured-img {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }
  .ev-article-featured-img img {
    width: 100%;
    height: auto;
    display: block;
  }
  .ev-article-content {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.8;
  }
  .ev-article-content h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin: var(--space-8) 0 var(--space-4);
    color: var(--color-text);
  }
  .ev-article-content h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin: var(--space-6) 0 var(--space-3);
    color: var(--color-text);
  }
  .ev-article-content p {
    margin-bottom: var(--space-4);
  }
  .ev-article-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-5) 0;
  }
  .ev-article-content ul,
  .ev-article-content ol {
    margin: var(--space-4) 0;
    padding-left: var(--space-5);
  }
  .ev-article-content li {
    margin-bottom: var(--space-2);
  }
  .ev-article-content blockquote {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-4) var(--space-5);
    margin: var(--space-6) 0;
    background: var(--gray-50);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
    color: var(--color-text-light);
  }
  .ev-article-content a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .ev-article-content a:hover {
    color: var(--color-accent);
  }
  .ev-article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--gray-200);
  }
  .ev-article-tag {
    display: inline-block;
    background: rgba(239,210,167,0.15);
    color: var(--color-text);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
  }
  .ev-article-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-8);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .ev-article-back:hover {
    color: var(--color-accent);
    gap: var(--space-3);
  }
  @media (max-width: 549px) {
    .ev-article { padding: var(--space-7) var(--space-4) var(--space-9); }
    .ev-article-header h1 { font-size: var(--text-xl); }
  }
{%- endstyle -%}

<article class="ev-article">
  <header class="ev-article-header reveal">
    <h1>{{ article.title }}</h1>
    <div class="ev-article-meta">
      <span>{{ article.author }}</span>
      <span class="ev-article-meta-sep"></span>
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{ article.published_at | date: '%d. %B %Y' }}
      </time>
    </div>
  </header>

  {%- if article.image -%}
    <div class="ev-article-featured-img reveal">
      <img
        src="{{ article.image | image_url: width: 1200 }}"
        alt="{{ article.image.alt | default: article.title | escape }}"
        width="1200"
        height="{{ 1200 | divided_by: article.image.aspect_ratio | round }}"
      >
    </div>
  {%- endif -%}

  <div class="ev-article-content rte reveal">
    {{ article.content }}
  </div>

  {%- if article.tags.size > 0 -%}
    <div class="ev-article-tags">
      {%- for tag in article.tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="ev-article-tag">{{ tag }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <a href="{{ blog.url }}" class="ev-article-back">&larr; Zurück zum Blog</a>
</article>

{% schema %}
{
  "name": "EVERLOXX Artikel",
  "tag": "section",
  "settings": []
}
{% endschema %}
